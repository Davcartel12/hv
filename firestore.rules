rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    match /users/{uid} {
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list: if request.auth != null && resource.data.referredBy != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }

    match /deposits/{doc} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow read, write: if isAdmin();
    }

    match /withdrawals/{doc} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow read, write: if isAdmin();
    }

    match /transactions/{doc} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /settings/{doc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /packages/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /support_threads/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }

    match /support_threads/{uid}/messages/{msg} {
      allow read, create: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }

    match /support_messages/{doc} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /giftcards/{doc} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if request.auth != null;
    }

    // One account, one withdrawal address.
    // Doc ID = provider + normalized number (e.g. opay_2348063804264).
    // Create-only: a binding can never be overwritten or deleted by users,
    // so the same number can never be claimed by a second account.
    match /wallet_bindings/{addressKey} {
      allow get: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, write: if isAdmin();
    }
  }
}
